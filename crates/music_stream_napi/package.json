{
	"name": "@rhythm-app/streamer",
	"version": "0.1.0",
	"description": "Low-latency audio decode, Opus encode, and RTP/RTCP streaming runtime for Node.js",
	"keywords": [
		"audio",
		"napi-rs",
		"opus",
		"rtp",
		"streaming"
	],
	"license": "AGPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PluxelJS/rhythm-napi.git"
	},
	"files": [
		"index.js",
		"index.d.ts"
	],
	"type": "commonjs",
	"main": "./index.js",
	"types": "./index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"require": "./index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "napi build --platform --release",
		"build:debug": "napi build --platform",
		"artifacts": "napi artifacts",
		"create:npm": "napi create-npm-dirs",
		"prepublishOnly": "napi pre-publish -t npm --gh-release",
		"soak": "npm run build && node scripts/soak.mjs",
		"test": "npm run build:debug && tsc --noEmit && vitest run",
		"version": "napi version && git add npm"
	},
	"devDependencies": {
		"@napi-rs/cli": "3.7.4",
		"@types/node": "26.1.1",
		"typescript": "7.0.2",
		"vitest": "4.1.10"
	},
	"napi": {
		"binaryName": "rhythm_streamer",
		"targets": [
			"x86_64-unknown-linux-gnu",
			"x86_64-pc-windows-msvc",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin"
		]
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "npm@11.17.0"
}
