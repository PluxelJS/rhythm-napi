{
  "name": "@rhythm-app/streamer",
  "version": "0.1.0",
  "description": "Low-latency audio decode, Opus encode, and RTP/RTCP streaming runtime for Node.js",
  "license": "AGPL-3.0-or-later",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "type": "commonjs",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js"
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts",
    "create:npm": "napi create-npm-dirs",
    "prepublishOnly": "napi pre-publish -t npm --gh-release",
    "test": "npm run build:debug && tsc --noEmit && vitest run",
    "version": "napi version && git add npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.2",
    "@types/node": "24.13.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "napi": {
    "binaryName": "rhythm_streamer",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.17.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kokoro-js/rhythm-napi.git"
  },
  "keywords": [
    "napi-rs",
    "audio",
    "opus",
    "rtp",
    "streaming"
  ]
}
